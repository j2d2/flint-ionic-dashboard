{
  "name": "flint-dashboard-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express + Socket.io bridge between Ionic dashboard and Flint MCP",
  "scripts": {
    "dev": "lsof -ti:${PORT:-18310} | xargs kill -9 2>/dev/null; ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
