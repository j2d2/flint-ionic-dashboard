# --- Flint dashboard backend ---

# Flint MCP server URL (never change for local dev or EVO — Flint always binds localhost)
FLINT_MCP_URL=http://127.0.0.1:18765/mcp

# Vault path — absolute path to obsidian-vault root on this machine
# MacBook dev:
VAULT_PATH=/Users/jd/Documents/ai-ml/openclaw-instance/projects/obsidian-vault
# EVO-X2 (uncomment when migrating):
# VAULT_PATH=/home/jd/projects/obsidian-vault

# Flint tool call log (append-only, never mutated by this backend — read only)
FLINT_TOOL_CALLS_LOG=/Users/jd/.openclaw/flint_tool_calls.jsonl

# Escalation policy — Flint's best-model-first principle.
# DISABLE_ESCALATION=false → dashboard backend can call query_claude_api via Flint
# when confidence < threshold. Set true only if ANTHROPIC_API_KEY is unavailable.
LOCAL_ONLY=false
DISABLE_ESCALATION=false

# Backend port (Angular proxies /api and /socket.io here)
PORT=18310

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:18320,capacitor://localhost
